{"post_content":"<!-- wp:heading -->\n<h2 class=\"wp-block-heading\"><strong>Day 1 \u2013 DevOps Fundamentals<\/strong><\/h2>\n<!-- \/wp:heading -->\n\n<!-- wp:heading {\"level\":3} -->\n<h3 class=\"wp-block-heading\"><strong>Module 1: What is DevOps?<\/strong><\/h3>\n<!-- \/wp:heading -->\n\n<!-- wp:list -->\n<ul class=\"wp-block-list\"><!-- wp:list-item -->\n<li>The evolution of DevOps<\/li>\n<!-- \/wp:list-item -->\n\n<!-- wp:list-item -->\n<li>DevOps vs. traditional IT<\/li>\n<!-- \/wp:list-item -->\n\n<!-- wp:list-item -->\n<li>Core principles: Collaboration, automation, measurement, sharing (CAMS)<\/li>\n<!-- \/wp:list-item -->\n\n<!-- wp:list-item -->\n<li>Benefits of DevOps for businesses and teams<\/li>\n<!-- \/wp:list-item --><\/ul>\n<!-- \/wp:list -->\n\n<!-- wp:heading {\"level\":3} -->\n<h3 class=\"wp-block-heading\"><strong>Module 2: DevOps Culture and Collaboration<\/strong><\/h3>\n<!-- \/wp:heading -->\n\n<!-- wp:list -->\n<ul class=\"wp-block-list\"><!-- wp:list-item -->\n<li>Breaking down silos between Dev and Ops<\/li>\n<!-- \/wp:list-item -->\n\n<!-- wp:list-item -->\n<li>Agile and Lean methodologies in DevOps<\/li>\n<!-- \/wp:list-item -->\n\n<!-- wp:list-item -->\n<li>Communication and collaboration best practices<\/li>\n<!-- \/wp:list-item -->\n\n<!-- wp:list-item -->\n<li>The role of Site Reliability Engineering (SRE)<\/li>\n<!-- \/wp:list-item --><\/ul>\n<!-- \/wp:list -->\n\n<!-- wp:heading {\"level\":3} -->\n<h3 class=\"wp-block-heading\"><strong>Module 3: Continuous Integration (CI) Essentials<\/strong><\/h3>\n<!-- \/wp:heading -->\n\n<!-- wp:list -->\n<ul class=\"wp-block-list\"><!-- wp:list-item -->\n<li>What is CI, and why is it important?<\/li>\n<!-- \/wp:list-item -->\n\n<!-- wp:list-item -->\n<li>Setting up a CI pipeline<\/li>\n<!-- \/wp:list-item -->\n\n<!-- wp:list-item -->\n<li>Common CI tools: Jenkins, GitHub Actions, GitLab CI, CircleCI<\/li>\n<!-- \/wp:list-item -->\n\n<!-- wp:list-item -->\n<li>Hands-on: Automating builds and tests in a CI\/CD pipeline<\/li>\n<!-- \/wp:list-item --><\/ul>\n<!-- \/wp:list -->\n\n<!-- wp:heading {\"level\":3} -->\n<h3 class=\"wp-block-heading\"><strong>Module 4: Continuous Delivery (CD) &amp; Deployment<\/strong><\/h3>\n<!-- \/wp:heading -->\n\n<!-- wp:list -->\n<ul class=\"wp-block-list\"><!-- wp:list-item -->\n<li>What is Continuous Delivery vs. Continuous Deployment?<\/li>\n<!-- \/wp:list-item -->\n\n<!-- wp:list-item -->\n<li>Deployment strategies (blue-green, canary, rolling updates)<\/li>\n<!-- \/wp:list-item -->\n\n<!-- wp:list-item -->\n<li>Common CD tools: ArgoCD, Spinnaker, GitOps<\/li>\n<!-- \/wp:list-item -->\n\n<!-- wp:list-item -->\n<li>Hands-on: Deploying a sample application<\/li>\n<!-- \/wp:list-item --><\/ul>\n<!-- \/wp:list -->\n\n<!-- wp:heading {\"level\":3} -->\n<h3 class=\"wp-block-heading\"><strong>Module 5: Version Control and Git Best Practices<\/strong><\/h3>\n<!-- \/wp:heading -->\n\n<!-- wp:list -->\n<ul class=\"wp-block-list\"><!-- wp:list-item -->\n<li>Why version control is essential in DevOps<\/li>\n<!-- \/wp:list-item -->\n\n<!-- wp:list-item -->\n<li>Git workflows: Git Flow, GitHub Flow, Trunk-Based Development<\/li>\n<!-- \/wp:list-item -->\n\n<!-- wp:list-item -->\n<li>Hands-on: Branching, merging, and managing pull requests<\/li>\n<!-- \/wp:list-item --><\/ul>\n<!-- \/wp:list -->\n\n<!-- wp:separator -->\n<hr class=\"wp-block-separator has-alpha-channel-opacity\"\/>\n<!-- \/wp:separator -->\n\n<!-- wp:heading -->\n<h2 class=\"wp-block-heading\"><strong>Day 2 \u2013 DevOps Tooling &amp; Infrastructure as Code (IaC)<\/strong><\/h2>\n<!-- \/wp:heading -->\n\n<!-- wp:heading {\"level\":3} -->\n<h3 class=\"wp-block-heading\"><strong>Module 6: Infrastructure as Code (IaC) Fundamentals<\/strong><\/h3>\n<!-- \/wp:heading -->\n\n<!-- wp:list -->\n<ul class=\"wp-block-list\"><!-- wp:list-item -->\n<li>What is Infrastructure as Code?<\/li>\n<!-- \/wp:list-item -->\n\n<!-- wp:list-item -->\n<li>Declarative vs. imperative approaches<\/li>\n<!-- \/wp:list-item -->\n\n<!-- wp:list-item -->\n<li>Common IaC tools: Terraform, Ansible, CloudFormation<\/li>\n<!-- \/wp:list-item -->\n\n<!-- wp:list-item -->\n<li>Hands-on: Writing and applying basic Terraform configurations<\/li>\n<!-- \/wp:list-item --><\/ul>\n<!-- \/wp:list -->\n\n<!-- wp:heading {\"level\":3} -->\n<h3 class=\"wp-block-heading\"><strong>Module 7: Configuration Management &amp; Automation<\/strong><\/h3>\n<!-- \/wp:heading -->\n\n<!-- wp:list -->\n<ul class=\"wp-block-list\"><!-- wp:list-item -->\n<li>The need for automation in DevOps<\/li>\n<!-- \/wp:list-item -->\n\n<!-- wp:list-item -->\n<li>Tools overview: Ansible, Puppet, Chef<\/li>\n<!-- \/wp:list-item -->\n\n<!-- wp:list-item -->\n<li>Hands-on: Automating configurations with Ansible<\/li>\n<!-- \/wp:list-item --><\/ul>\n<!-- \/wp:list -->\n\n<!-- wp:heading {\"level\":3} -->\n<h3 class=\"wp-block-heading\"><strong>Module 8: Monitoring, Logging, and Observability<\/strong><\/h3>\n<!-- \/wp:heading -->\n\n<!-- wp:list -->\n<ul class=\"wp-block-list\"><!-- wp:list-item -->\n<li>Why monitoring is crucial for DevOps<\/li>\n<!-- \/wp:list-item -->\n\n<!-- wp:list-item -->\n<li>Metrics, logs, and traces<\/li>\n<!-- \/wp:list-item -->\n\n<!-- wp:list-item -->\n<li>Tools overview: Prometheus, Grafana, ELK Stack, Datadog<\/li>\n<!-- \/wp:list-item -->\n\n<!-- wp:list-item -->\n<li>Hands-on: Setting up basic monitoring for an application<\/li>\n<!-- \/wp:list-item --><\/ul>\n<!-- \/wp:list -->\n\n<!-- wp:heading {\"level\":3} -->\n<h3 class=\"wp-block-heading\"><strong>Module 9: Security in DevOps (DevSecOps)<\/strong><\/h3>\n<!-- \/wp:heading -->\n\n<!-- wp:list -->\n<ul class=\"wp-block-list\"><!-- wp:list-item -->\n<li>The importance of security in DevOps<\/li>\n<!-- \/wp:list-item -->\n\n<!-- wp:list-item -->\n<li>Shifting left: Integrating security into CI\/CD<\/li>\n<!-- \/wp:list-item -->\n\n<!-- wp:list-item -->\n<li>Tools overview: Snyk, Trivy, OWASP ZAP<\/li>\n<!-- \/wp:list-item -->\n\n<!-- wp:list-item -->\n<li>Hands-on: Scanning for vulnerabilities in a containerized app<\/li>\n<!-- \/wp:list-item --><\/ul>\n<!-- \/wp:list -->\n\n<!-- wp:heading {\"level\":3} -->\n<h3 class=\"wp-block-heading\"><strong>Module 10: DevOps in the Cloud<\/strong><\/h3>\n<!-- \/wp:heading -->\n\n<!-- wp:list -->\n<ul class=\"wp-block-list\"><!-- wp:list-item -->\n<li>Cloud-native DevOps practices<\/li>\n<!-- \/wp:list-item -->\n\n<!-- wp:list-item -->\n<li>DevOps on AWS, Azure, and Google Cloud<\/li>\n<!-- \/wp:list-item -->\n\n<!-- wp:list-item -->\n<li>Serverless and Kubernetes in DevOps<\/li>\n<!-- \/wp:list-item -->\n\n<!-- wp:list-item -->\n<li>Hands-on: Deploying an app using cloud DevOps services<\/li>\n<!-- \/wp:list-item --><\/ul>\n<!-- \/wp:list -->\n\n<!-- wp:separator -->\n<hr class=\"wp-block-separator has-alpha-channel-opacity\"\/>\n<!-- \/wp:separator -->\n\n<!-- wp:heading -->\n<h2 class=\"wp-block-heading\"><strong>Hands-on Labs &amp; Final Project<\/strong><\/h2>\n<!-- \/wp:heading -->\n\n<!-- wp:list -->\n<ul class=\"wp-block-list\"><!-- wp:list-item -->\n<li><strong>Lab 1<\/strong>: Setting up a CI\/CD pipeline<\/li>\n<!-- \/wp:list-item -->\n\n<!-- wp:list-item -->\n<li><strong>Lab 2<\/strong>: Writing Terraform for cloud infrastructure<\/li>\n<!-- \/wp:list-item -->\n\n<!-- wp:list-item -->\n<li><strong>Lab 3<\/strong>: Automating server configurations with Ansible<\/li>\n<!-- \/wp:list-item -->\n\n<!-- wp:list-item -->\n<li><strong>Lab 4<\/strong>: Setting up monitoring and logging<\/li>\n<!-- \/wp:list-item -->\n\n<!-- wp:list-item -->\n<li><strong>Final Project<\/strong>: Implementing a mini DevOps workflow for an application<\/li>\n<!-- \/wp:list-item --><\/ul>\n<!-- \/wp:list -->","post_type":"training","post_status":"publish","post_name":"introduction-to-devops","post_title":"Introduction to DevOps","post_password":"","post_date":"2025-02-22 09:39:22","post_date_gmt":"2025-02-22 09:39:22","post_excerpt":"This 2-day hands-on trai