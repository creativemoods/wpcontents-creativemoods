{"post_content":"<!-- wp:generateblocks\/container {\"uniqueId\":\"643a2263\",\"isDynamic\":true,\"blockVersion\":4,\"display\":\"flex\",\"flexDirectionTablet\":\"column\",\"alignItems\":\"center\",\"alignItemsTablet\":\"center\",\"columnGap\":\"100px\",\"position\":\"relative\",\"zindex\":2,\"sizing\":{\"height\":\"\",\"maxWidth\":\"\"},\"useGlobalMaxWidth\":true,\"spacing\":{\"paddingTop\":\"0px\",\"paddingRight\":\"30px\",\"paddingBottom\":\"60px\",\"paddingLeft\":\"30px\",\"marginTop\":\"-60px\",\"marginRight\":\"auto\",\"marginLeft\":\"auto\"}} -->\n<!-- wp:generateblocks\/container {\"uniqueId\":\"c41599c6\",\"removeVerticalGapTablet\":true,\"removeVerticalGapMobile\":true,\"isDynamic\":true,\"blockVersion\":4,\"orderTablet\":2,\"sizing\":{\"width\":\"50%\",\"widthTablet\":\"75%\",\"widthMobile\":\"100%\",\"height\":\"\",\"maxWidth\":\"\"},\"spacing\":{\"paddingTop\":\"0px\",\"paddingRight\":\"0px\",\"paddingBottom\":\"0px\",\"paddingLeft\":\"0px\"}} -->\n<!-- wp:generateblocks\/headline {\"uniqueId\":\"f7c2011f\",\"blockVersion\":3,\"spacing\":{\"paddingTop\":\"120px\",\"paddingTopTablet\":\"0px\"}} -->\n<h2 class=\"gb-headline gb-headline-f7c2011f gb-headline-text\">Bring the Power of Git to Your WordPress Workflow<\/h2>\n<!-- \/wp:generateblocks\/headline -->\n\n<!-- wp:paragraph -->\n<p>PushPull is a WordPress plugin that transforms the way you manage and deploy your WordPress sites by seamlessly integrating with Git repositories. With PushPull, you can version-control every aspect of your WordPress instance\u2014content, themes, plugins, and configuration\u2014bringing the full power of DevOps to your WordPress workflow.<\/p>\n<!-- \/wp:paragraph -->\n\n<!-- wp:paragraph -->\n<p>Find <a href=\"https:\/\/github.com\/creativemoods\/pushpull\" target=\"_blank\" rel=\"noopener\" title=\"PushPull on GitHub\">PushPull on GitHub<\/a><\/p>\n<!-- \/wp:paragraph -->\n<!-- \/wp:generateblocks\/container -->\n\n<!-- wp:generateblocks\/container {\"uniqueId\":\"b00a1ca5\",\"isDynamic\":true,\"blockVersion\":4,\"orderTablet\":1,\"sizing\":{\"width\":\"50%\",\"widthTablet\":\"100%\",\"widthMobile\":\"100%\",\"height\":\"\",\"maxWidth\":\"\"},\"typography\":{\"textAlign\":\"center\"},\"spacing\":{\"paddingTop\":\"0px\",\"paddingRight\":\"0px\",\"paddingBottom\":\"0px\",\"paddingLeft\":\"0px\"}} -->\n<!-- wp:image {\"lightbox\":{\"enabled\":false},\"id\":52,\"width\":\"500px\",\"sizeSlug\":\"full\",\"linkDestination\":\"custom\",\"align\":\"center\",\"className\":\"is-style-default\"} -->\n<figure class=\"wp-block-image aligncenter size-full is-resized is-style-default\"><a href=\"https:\/\/github.com\/creativemoods\/pushpull\" target=\"_blank\" rel=\"noreferrer noopener\"><img src=\"@@DOMAIN@@\/app\/uploads\/PushPull-Main-Logo.png\" alt=\"\" class=\"wp-image-52\" style=\"width:500px\"\/><\/a><\/figure>\n<!-- \/wp:image -->\n<!-- \/wp:generateblocks\/container -->\n<!-- \/wp:generateblocks\/container -->\n\n<!-- wp:generateblocks\/container {\"uniqueId\":\"da48d90b\",\"gradient\":true,\"gradientDirection\":180,\"gradientColorOne\":\"var(\\u002d\\u002dbase-2)\",\"gradientColorOneOpacity\":1,\"gradientColorTwo\":\"var(\\u002d\\u002dbase-3)\",\"gradientColorTwoOpacity\":1,\"bgImage\":{\"id\":1034,\"image\":{\"height\":155.19,\"width\":400,\"url\":\"@@DOMAIN@@\/app\/uploads\/abstract-shapes.svg\",\"orientation\":\"portrait\"}},\"bgOptions\":{\"selector\":\"pseudo-element\",\"opacity\":1,\"overlay\":false,\"position\":\"center top\",\"size\":\"full\",\"repeat\":\"no-repeat\",\"attachment\":\"\"},\"innerZindex\":1,\"shapeDividers\":[{\"shape\":\"gb-triangle-1\",\"color\":\"var(\\u002d\\u002dbase-3)\",\"colorOpacity\":1,\"location\":\"top\",\"height\":50,\"heightTablet\":\"\",\"heightMobile\":\"\",\"width\":100,\"widthTablet\":150,\"widthMobile\":200,\"flipHorizontally\":false,\"zindex\":null}],\"isDynamic\":true,\"blockVersion\":4,\"position\":\"relative\",\"overflowX\":\"hidden\",\"overflowY\":\"hidden\",\"sizing\":{\"height\":\"\",\"maxWidth\":\"\"}} -->\n<!-- wp:generateblocks\/container {\"uniqueId\":\"2cb92c67\",\"isDynamic\":true,\"blockVersion\":4,\"position\":\"relative\",\"zindex\":1,\"sizing\":{\"maxWidth\":\"\"},\"useGlobalMaxWidth\":true,\"spacing\":{\"paddingTop\":\"130px\",\"paddingRight\":\"30px\",\"paddingBottom\":\"0px\",\"paddingLeft\":\"30px\",\"marginRight\":\"auto\",\"marginLeft\":\"auto\"}} -->\n<!-- wp:generateblocks\/grid {\"uniqueId\":\"fc495083\",\"columns\":9,\"horizontalGap\":80,\"verticalGap\":80,\"horizontalAlignmentTablet\":\"center\",\"isDynamic\":true,\"blockVersion\":3,\"useLegacyRowGap\":true} -->\n<!-- wp:generateblocks\/container {\"uniqueId\":\"eb42ddb4\",\"isGrid\":true,\"gridId\":\"fc495083\",\"backgroundColor\":\"var(\\u002d\\u002dbase-3)\",\"bgImage\":{\"id\":1124,\"image\":{\"height\":101.2,\"width\":100,\"url\":\"@@DOMAIN@@\/app\/uploads\/dots-1-1.svg\",\"orientation\":\"portrait\"}},\"bgOptions\":{\"selector\":\"pseudo-element\",\"opacity\":0.08,\"overlay\":false,\"position\":\"right 20px top 20px\",\"size\":\"160px\",\"repeat\":\"no-repeat\",\"attachment\":\"\"},\"innerZindex\":1,\"isDynamic\":true,\"blockVersion\":4,\"position\":\"relative\",\"overflowX\":\"hidden\",\"overflowY\":\"hidden\",\"sizing\":{\"width\":\"50%\",\"widthTablet\":\"75%\",\"widthMobile\":\"100%\",\"height\":\"100%\",\"maxWidth\":\"\"},\"spacing\":{\"paddingTop\":\"40px\",\"paddingRight\":\"30px\",\"paddingBottom\":\"30px\",\"paddingLeft\":\"40px\"},\"borders\":{\"borderTopWidth\":\"1px\",\"borderTopStyle\":\"solid\",\"borderTopColor\":\"var(\\u002d\\u002dbase)\",\"borderRightWidth\":\"1px\",\"borderRightStyle\":\"solid\",\"borderRightColor\":\"var(\\u002d\\u002dbase)\",\"borderBottomWidth\":\"1px\",\"borderBottomStyle\":\"solid\",\"borderBottomColor\":\"var(\\u002d\\u002dbase)\",\"borderLeftWidth\":\"1px\",\"borderLeftStyle\":\"solid\",\"borderLeftColor\":\"var(\\u002d\\u002dbase)\",\"borderTopRightRadius\":\"8px\",\"borderBottomRightRadius\":\"8px\",\"borderBottomLeftRadius\":\"8px\",\"borderTopLeftRadius\":\"8px\"}} -->\n<!-- wp:generateblocks\/headline {\"uniqueId\":\"918c740e\",\"element\":\"h3\",\"blockVersion\":3,\"display\":\"flex\",\"alignItems\":\"center\",\"justifyContent\":\"flex-start\",\"typography\":{\"textAlign\":\"left\"},\"iconStyles\":{\"width\":\"80px\",\"height\":\"80px\",\"paddingRight\":\"0.5em\"}} -->\n<h3 class=\"gb-headline gb-headline-918c740e gb-headline-text\">\u2705 Version Control Everything<\/h3>\n<!-- \/wp:generateblocks\/headline -->\n\n<!-- wp:paragraph -->\n<p>PushPull stores all of your WordPress site\u2019s contents, database configuration, themes, and plugins in a Git repository. Easily track changes, roll back updates, and collaborate with your team efficiently.<\/p>\n<!-- \/wp:paragraph -->\n<!-- \/wp:generateblocks\/container -->\n\n<!-- wp:generateblocks\/container {\"uniqueId\":\"f8f190a2\",\"isGrid\":true,\"gridId\":\"fc495083\",\"backgroundColor\":\"var(\\u002d\\u002dbase-3)\",\"bgImage\":{\"id\":1124,\"image\":{\"height\":101.2,\"width\":100,\"url\":\"@@DOMAIN@@\/app\/uploads\/dots-1-1.svg\",\"orientation\":\"portrait\"}},\"bgOptions\":{\"selector\":\"pseudo-element\",\"opacity\":0.08,\"overlay\":false,\"position\":\"right 20px top 20px\",\"size\":\"160px\",\"repeat\":\"no-repeat\",\"attachment\":\"\"},\"innerZindex\":1,\"isDynamic\":true,\"blockVersion\":4,\"position\":\"relative\",\"overflowX\":\"hidden\",\"overflowY\":\"hidden\",\"sizing\":{\"width\":\"50%\",\"widthTablet\":\"75%\",\"widthMobile\":\"100%\",\"height\":\"100%\",\"maxWidth\":\"\"},\"spacing\":{\"paddingTop\":\"40px\",\"paddingRight\":\"30px\",\"paddingBottom\":\"30px\",\"paddingLeft\":\"40px\"},\"borders\":{\"borderTopWidth\":\"1px\",\"borderTopStyle\":\"solid\",\"borderTopColor\":\"var(\\u002d\\u002dbase)\",\"borderRightWidth\":\"1px\",\"borderRightStyle\":\"solid\",\"borderRightColor\":\"var(\\u002d\\u002dbase)\",\"borderBottomWidth\":\"1px\",\"borderBottomStyle\":\"solid\",\"borderBottomColor\":\"var(\\u002d\\u002dbase)\",\"borderLeftWidth\":\"1px\",\"borderLeftStyle\":\"solid\",\"borderLeftColor\":\"var(\\u002d\\u002dbase)\",\"borderTopRightRadius\":\"8px\",\"borderBottomRightRadius\":\"8px\",\"borderBottomLeftRadius\":\"8px\",\"borderTopLeftRadius\":\"8px\"}} -->\n<!-- wp:generateblocks\/headline {\"uniqueId\":\"c40d536d\",\"element\":\"h3\",\"blockVersion\":3,\"display\":\"flex\",\"alignItems\":\"center\",\"justifyContent\":\"flex-start\",\"typography\":{\"textAlign\":\"left\"},\"iconStyles\":{\"width\":\"80px\",\"height\":\"80px\",\"paddingRight\":\"0.5em\"}} -->\n<h3 class=\"gb-headline gb-headline-c40d536d gb-headline-text\">\ud83d\ude80 Streamlined Deployments<\/h3>\n<!-- \/wp:generateblocks\/headline -->\n\n<!-- wp:paragraph -->\n<p>Say goodbye to tedious manual updates! PushPull enables automated deployments, allowing you to push changes from development to production seamlessly. No more unexpected issues when updating your WordPress site.<\/p>\n<!-- \/wp:paragraph -->\n<!-- \/wp:generateblocks\/container -->\n\n<!-- wp:generateblocks\/container {\"uniqueId\":\"ba81ee1e\",\"isGrid\":true,\"gridId\":\"fc495083\",\"backgroundColor\":\"var(\\u002d\\u002dbase-3)\",\"bgImage\":{\"id\":1124,\"image\":{\"height\":101.2,\"width\":100,\"url\":\"@@DOMAIN@@\/app\/uploads\/dots-1-1.svg\",\"orientation\":\"portrait\"}},\"bgOptions\":{\"selector\":\"pseudo-element\",\"opacity\":0.08,\"overlay\":false,\"position\":\"right 20px top 20px\",\"size\":\"160px\",\"repeat\":\"no-repeat\",\"attachment\":\"\"},\"innerZindex\":1,\"isDynamic\":true,\"blockVersion\":4,\"position\":\"relative\",\"overflowX\":\"hidden\",\"overflowY\":\"hidden\",\"sizing\":{\"width\":\"50%\",\"widthTablet\":\"75%\",\"widthMobile\":\"100%\",\"height\":\"100%\",\"maxWidth\":\"\"},\"spacing\":{\"paddingTop\":\"40px\",\"paddingRight\":\"30px\",\"paddingBottom\":\"30px\",\"paddingLeft\":\"40px\"},\"borders\":{\"borderTopWidth\":\"1px\",\"borderTopStyle\":\"solid\",\"borderTopColor\":\"var(\\u002d\\u002dbase)\",\"borderRightWidth\":\"1px\",\"borderRightStyle\":\"solid\",\"borderRightColor\":\"var(\\u002d\\u002dbase)\",\"borderBottomWidth\":\"1px\",\"borderBottomStyle\":\"solid\",\"borderBottomColor\":\"var(\\u002d\\u002dbase)\",\"borderLeftWidth\":\"1px\",\"borderLeftStyle\":\"solid\",\"borderLeftColor\":\"var(\\u002d\\u002dbase)\",\"borderTopRightRadius\":\"8px\",\"borderBottomRightRadius\":\"8px\",\"borderBottomLeftRadius\":\"8px\",\"borderTopLeftRadius\":\"8px\"}} -->\n<!-- wp:generateblocks\/headline {\"uniqueId\":\"5dab13f4\",\"element\":\"h3\",\"blockVersion\":3,\"display\":\"flex\",\"alignItems\":\"center\",\"justifyContent\":\"flex-start\",\"typography\":{\"textAlign\":\"left\"},\"iconStyles\":{\"width\":\"80px\",\"height\":\"80px\",\"paddingRight\":\"0.5em\"}} -->\n<h3 class=\"gb-headline gb-headline-5dab13f4 gb-headline-text\">\ud83d\udd04 Continuous Integration &amp; Continuous Deployment (CI\/CD)<\/h3>\n<!-- \/wp:generateblocks\/headline -->\n\n<!-- wp:paragraph -->\n<p>Automate your WordPress deployments with CI\/CD pipelines. PushPull integrates with GitHub, GitLab, and Bitbucket to enable automated testing and deployment of WordPress updates, reducing downtime and improving reliability.<\/p>\n<!-- \/wp:paragraph -->\n<!-- \/wp:generateblocks\/container -->\n\n<!-- wp:generateblocks\/container {\"uniqueId\":\"6d8fd4ab\",\"isGrid\":true,\"gridId\":\"fc495083\",\"backgroundColor\":\"var(\\u002d\\u002dbase-3)\",\"bgImage\":{\"id\":1124,\"image\":{\"height\":101.2,\"width\":100,\"url\":\"@@DOMAIN@@\/app\/uploads\/dots-1-1.svg\",\"orientation\":\"portrait\"}},\"bgOptions\":{\"selector\":\"pseudo-element\",\"opacity\":0.08,\"overlay\":false,\"position\":\"right 20px top 20px\",\"size\":\"160px\",\"repeat\":\"no-repeat\",\"attachment\":\"\"},\"innerZindex\":1,\"isDynamic\":true,\"blockVersion\":4,\"position\":\"relative\",\"overflowX\":\"hidden\",\"overflowY\":\"hidden\",\"sizing\":{\"width\":\"50%\",\"widthTablet\":\"75%\",\"widthMobile\":\"100%\",\"height\":\"100%\",\"maxWidth\":\"\"},\"spacing\":{\"paddingTop\":\"40px\",\"paddingRight\":\"30px\",\"paddingBottom\":\"30px\",\"paddingLeft\":\"40px\"},\"borders\":{\"borderTopWidth\":\"1px\",\"borderTopStyle\":\"solid\",\"borderTopColor\":\"var(\\u002d\\u002dbase)\",\"borderRightWidth\":\"1px\",\"borderRightStyle\":\"solid\",\"borderRightColor\":\"var(\\u002d\\u002dbase)\",\"borderBottomWidth\":\"1px\",\"borderBottomStyle\":\"solid\",\"borderBottomColor\":\"var(\\u002d\\u002dbase)\",\"borderLeftWidth\":\"1px\",\"borderLeftStyle\":\"solid\",\"borderLeftColor\":\"var(\\u002d\\u002dbase)\",\"borderTopRightRadius\":\"8px\",\"borderBottomRightRadius\":\"8px\",\"borderBottomLeftRadius\":\"8px\",\"borderTopLeftRadius\":\"8px\"}} -->\n<!-- wp:generateblocks\/headline {\"uniqueId\":\"9034ab35\",\"element\":\"h3\",\"blockVersion\":3,\"display\":\"flex\",\"alignItems\":\"center\",\"justifyContent\":\"flex-start\",\"typography\":{\"textAlign\":\"left\"},\"iconStyles\":{\"width\":\"80px\",\"height\":\"80px\",\"paddingRight\":\"0.5em\"}} -->\n<h3 class=\"gb-headline gb-headline-9034ab35 gb-headline-text\">\ud83d\udd12 Enhanced Security &amp; Rollback Capabilities<\/h3>\n<!-- \/wp:generateblocks\/headline -->\n\n<!-- wp:paragraph -->\n<p>With Git-based version control, every change is logged and reversible. Quickly roll back to a previous stable version if an update breaks your site. Plus, with secure Git hosting, your data remains safe and tamper-proof.<\/p>\n<!-- \/wp:paragraph -->\n<!-- \/wp:generateblocks\/container -->\n\n<!-- wp:generateblocks\/container {\"uniqueId\":\"421305df\",\"isGrid\":true,\"gridId\":\"fc495083\",\"backgroundColor\":\"var(\\u002d\\u002dbase-3)\",\"bgImage\":{\"id\":1124,\"image\":{\"height\":101.2,\"width\":100,\"url\":\"@@DOMAIN@@\/app\/uploads\/dots-1-1.svg\",\"orientation\":\"portrait\"}},\"bgOptions\":{\"selector\":\"pseudo-element\",\"opacity\":0.08,\"overlay\":false,\"position\":\"right 20px top 20px\",\"size\":\"160px\",\"repeat\":\"no-repeat\",\"attachment\":\"\"},\"innerZindex\":1,\"isDynamic\":true,\"blockVersion\":4,\"position\":\"relative\",\"overflowX\":\"hidden\",\"overflowY\":\"hidden\",\"sizing\":{\"width\":\"50%\",\"widthTablet\":\"75%\",\"widthMobile\":\"100%\",\"height\":\"100%\",\"maxWidth\":\"\"},\"spacing\":{\"paddingTop\":\"40px\",\"paddingRight\":\"30px\",\"paddingBottom\":\"30px\",\"paddingLeft\":\"40px\"},\"borders\":{\"borderTopWidth\":\"1px\",\"borderTopStyle\":\"solid\",\"borderTopColor\":\"var(\\u002d\\u002dbase)\",\"borderRightWidth\":\"1px\",\"borderRightStyle\":\"solid\",\"borderRightColor\":\"var(\\u002d\\u002dbase)\",\"borderBottomWidth\":\"1px\",\"borderBottomStyle\":\"solid\",\"borderBottomColor\":\"var(\\u002d\\u002dbase)\",\"borderLeftWidth\":\"1px\",\"borderLeftStyle\":\"solid\",\"borderLeftColor\":\"var(\\u002d\\u002dbase)\",\"borderTopRightRadius\":\"8px\",\"borderBottomRightRadius\":\"8px\",\"borderBottomLeftRadius\":\"8px\",\"borderTopLeftRadius\":\"8px\"}} -->\n<!-- wp:generateblocks\/headline {\"uniqueId\":\"5e3aa3ce\",\"element\":\"h3\",\"blockVersion\":3,\"display\":\"flex\",\"alignItems\":\"center\",\"justifyContent\":\"flex-start\",\"typography\":{\"textAlign\":\"left\"},\"iconStyles\":{\"width\":\"80px\",\"height\":\"80px\",\"paddingRight\":\"0.5em\"}} -->\n<h3 class=\"gb-headline gb-headline-5e3aa3ce gb-headline-text\">\ud83d\udcc1 Synchronize Across Environments<\/h3>\n<!-- \/wp:generateblocks\/headline -->\n\n<!-- wp:paragraph -->\n<p>Develop locally, test on staging, and deploy to production with confidence. PushPull ensures consistency across different environments, eliminating the classic \"it works on my machine\" problem.<\/p>\n<!-- \/wp:paragraph -->\n<!-- \/wp:generateblocks\/container -->\n\n<!-- wp:generateblocks\/container {\"uniqueId\":\"c8a6123f\",\"isGrid\":true,\"gridId\":\"fc495083\",\"backgroundColor\":\"var(\\u002d\\u002dbase-3)\",\"bgImage\":{\"id\":1124,\"image\":{\"height\":101.2,\"width\":100,\"url\":\"@@DOMAIN@@\/app\/uploads\/dots-1-1.svg\",\"orientation\":\"portrait\"}},\"bgOptions\":{\"selector\":\"pseudo-element\",\"opacity\":0.08,\"overlay\":false,\"position\":\"right 20px top 20px\",\"size\":\"160px\",\"repeat\":\"no-repeat\",\"attachment\":\"\"},\"innerZindex\":1,\"isDynamic\":true,\"blockVersion\":4,\"position\":\"relative\",\"overflowX\":\"hidden\",\"overflowY\":\"hidden\",\"sizing\":{\"width\":\"50%\",\"widthTablet\":\"75%\",\"widthMobile\":\"100%\",\"height\":\"100%\",\"maxWidth\":\"\"},\"spacing\":{\"paddingTop\":\"40px\",\"paddingRight\":\"30px\",\"paddingBottom\":\"30px\",\"paddingLeft\":\"40px\"},\"borders\":{\"borderTopWidth\":\"1px\",\"borderTopStyle\":\"solid\",\"borderTopColor\":\"var(\\u002d\\u002dbase)\",\"borderRightWidth\":\"1px\",\"borderRightStyle\":\"solid\",\"borderRightColor\":\"var(\\u002d\\u002dbase)\",\"borderBottomWidth\":\"1px\",\"borderBottomStyle\":\"solid\",\"borderBottomColor\":\"var(\\u002d\\u002dbase)\",\"borderLeftWidth\":\"1px\",\"borderLeftStyle\":\"solid\",\"borderLeftColor\":\"var(\\u002d\\u002dbase)\",\"borderTopRightRadius\":\"8px\",\"borderBottomRightRadius\":\"8px\",\"borderBottomLeftRadius\":\"8px\",\"borderTopLeftRadius\":\"8px\"}} -->\n<!-- wp:generateblocks\/headline {\"uniqueId\":\"d5fb233d\",\"element\":\"h3\",\"blockVersion\":3,\"display\":\"flex\",\"alignItems\":\"center\",\"justifyContent\":\"flex-start\",\"typography\":{\"textAlign\":\"left\"},\"iconStyles\":{\"width\":\"80px\",\"height\":\"80px\",\"paddingRight\":\"0.5em\"}} -->\n<h3 class=\"gb-headline gb-headline-d5fb233d gb-headline-text\">\u26a1 Easy Setup &amp; Integration<\/h3>\n<!-- \/wp:generateblocks\/headline -->\n\n<!-- wp:paragraph -->\n<p>PushPull is designed to be intuitive and easy to configure. Whether you are a developer or a site administrator, setting up Git-based management for your WordPress instance is straightforward.<\/p>\n<!-- \/wp:paragraph -->\n<!-- \/wp:generateblocks\/container -->\n\n<!-- wp:generateblocks\/container {\"uniqueId\":\"31625afb\",\"isGrid\":true,\"gridId\":\"fc495083\",\"backgroundColor\":\"var(\\u002d\\u002dbase-3)\",\"bgImage\":{\"id\":1124,\"image\":{\"height\":101.2,\"width\":100,\"url\":\"@@DOMAIN@@\/app\/uploads\/dots-1-1.svg\",\"orientation\":\"portrait\"}},\"bgOptions\":{\"selector\":\"pseudo-element\",\"opacity\":0.08,\"overlay\":false,\"position\":\"right 20px top 20px\",\"size\":\"160px\",\"repeat\":\"no-repeat\",\"attachment\":\"\"},\"innerZindex\":1,\"isDynamic\":true,\"blockVersion\":4,\"position\":\"relative\",\"overflowX\":\"hidden\",\"overflowY\":\"hidden\",\"sizing\":{\"width\":\"50%\",\"widthTablet\":\"75%\",\"widthMobile\":\"100%\",\"height\":\"100%\",\"maxWidth\":\"\"},\"spacing\":{\"paddingTop\":\"40px\",\"paddingRight\":\"30px\",\"paddingBottom\":\"30px\",\"paddingLeft\":\"40px\"},\"borders\":{\"borderTopWidth\":\"1px\",\"borderTopStyle\":\"solid\",\"borderTopColor\":\"var(\\u002d\\u002dbase)\",\"borderRightWidth\":\"1px\",\"borderRightStyle\":\"solid\",\"borderRightColor\":\"var(\\u002d\\u002dbase)\",\"borderBottomWidth\":\"1px\",\"borderBottomStyle\":\"solid\",\"borderBottomColor\":\"var(\\u002d\\u002dbase)\",\"borderLeftWidth\":\"1px\",\"borderLeftStyle\":\"solid\",\"borderLeftColor\":\"var(\\u002d\\u002dbase)\",\"borderTopRightRadius\":\"8px\",\"borderBottomRightRadius\":\"8px\",\"borderBottomLeftRadius\":\"8px\",\"borderTopLeftRadius\":\"8px\"}} -->\n<!-- wp:generateblocks\/headline {\"uniqueId\":\"cc1e5a2a\",\"element\":\"h3\",\"blockVersion\":3,\"display\":\"flex\",\"alignItems\":\"center\",\"justifyContent\":\"flex-start\",\"typography\":{\"textAlign\":\"left\"},\"iconStyles\":{\"width\":\"80px\",\"height\":\"80px\",\"paddingRight\":\"0.5em\"}} -->\n<h3 class=\"gb-headline gb-headline-cc1e5a2a gb-headline-text\">\ud83d\udd04 No More Manual Changes on Production<\/h3>\n<!-- \/wp:generateblocks\/headline -->\n\n<!-- wp:paragraph -->\n<p>With PushPull, there\u2019s no need to ever log into your live production environment to make manual changes. Every update is managed through version-controlled workflows and API